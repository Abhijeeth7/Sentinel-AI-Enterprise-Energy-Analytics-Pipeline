# --- Airflow Core Settings ---
# Use 'id -u' on Linux/Mac. For Windows, 50000 is the standard default.
AIRFLOW_UID=50000
# Generate a new key with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- AWS Infrastructure ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=sentinel-data-lake
AWS_REGION=us-east-1

# --- Snowflake Data Warehouse ---
# Only the account identifier (e.g., xy12345.us-east-1)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=SENTINEL_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH